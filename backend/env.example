# Copy this file to .env and fill in the values.
# Windows: copy env.example .env
# Mac/Linux: cp env.example .env

# MongoDB connection (required for contact messages)
MONGO_URI=mongodb://localhost:27017/portfolio

# Secret key to view messages at /admin (required to use admin page)
ADMIN_KEY=your-secret-admin-key-here

# Frontend URL (for CORS). Use your portfolio URL in production.
FRONTEND_URL=http://localhost:5173

# Backend port (optional, default 5000)
PORT=5000

# --- Optional: receive each message by email (runs only when NODE_ENV=production) ---
# See project root SMTP_SETUP.md for step-by-step (Gmail, Outlook, etc.).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@gmail.com
# CONTACT_EMAIL=your-email@gmail.com
