# Copy this file to .env and fill in the values.
# Windows: copy env.example .env
# Mac/Linux: cp env.example .env

# MongoDB connection (required for contact messages)
MONGO_URI=mongodb://localhost:27017/portfolio

# Secret key to view messages at /admin (required to use admin page)
ADMIN_KEY=your-secret-admin-key-here

# Frontend URL (for CORS). Use your portfolio URL in production.
FRONTEND_URL=http://localhost:5173

# Backend port (optional, default 5000)
PORT=5000

# --- Optional: receive each message by email ---
# Option A: SendGrid (recommended on Render – uses HTTPS, no blocked ports)
# Get API key at https://sendgrid.com; verify EMAIL_FROM in SendGrid dashboard.
# SENDGRID_API_KEY=SG.xxxx
# EMAIL_FROM=your-verified-email@example.com
# CONTACT_EMAIL=your-verified-email@example.com

# Option B: SMTP (e.g. local or Gmail). See project root SMTP_SETUP.md.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@gmail.com
# CONTACT_EMAIL=your-email@gmail.com
